{
  "name": "hivemind",
  "version": "1.13.0",
  "description": "Multi-terminal manager for Claude Code instances",
  "main": "dist-main/main.js",
  "scripts": {
    "compile:main": "tsc -p tsconfig.main.json",
    "dev": "npm run compile:main && concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "npm run compile:main && vite build && electron-builder",
    "start": "npm run compile:main && electron ."
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^11.0.2",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.hivemind.app",
    "productName": "Hivemind",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "npmRebuild": false,
    "nodeGypRebuild": false
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.1",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wait-on": "^9.0.4"
  }
}
